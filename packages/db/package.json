{
  "name": "@bgc-alpha/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "prisma generate --schema=./prisma/schema.prisma && tsc --noEmit",
    "typecheck": "prisma generate --schema=./prisma/schema.prisma && tsc --noEmit",
    "lint": "prisma generate --schema=./prisma/schema.prisma && tsc --noEmit",
    "test": "echo 'No tests yet for @bgc-alpha/db'",
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=./prisma/schema.prisma"
  },
  "exports": {
    ".": "./src/index.ts",
    "./database-url": "./src/database-url.ts",
    "./snapshot-storage": "./src/snapshot-storage.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1022.0",
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prisma": "^6.1.0",
    "typescript": "^5.7.2"
  }
}
