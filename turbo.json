{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "AUTH_SECRET",
    "AUTH_TRUST_HOST",
    "SEED_USER_PASSWORD",
    "SIMULATION_ENGINE_VERSION",
    "WORKER_CONCURRENCY",
    "S3_BUCKET",
    "S3_REGION",
    "S3_ACCESS_KEY_ID",
    "S3_SECRET_ACCESS_KEY",
    "POSTGRES_URL",
    "POSTGRES_DATABASE_URL",
    "POSTGRES_PRISMA_DATABASE_URL",
    "POSTGRES_PRISMA_URL",
    "POSTGRES_URL_NON_POOLING",
    "DATABASE_URL"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@bgc-alpha/web#build": {
      "outputs": [
        ".next/**"
      ]
    },
    "@bgc-alpha/worker#build": {
      "outputs": [
        "dist/**"
      ]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": [
        "coverage/**"
      ]
    }
  }
}
